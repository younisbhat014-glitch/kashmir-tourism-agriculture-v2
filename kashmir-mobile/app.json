{
  "expo": {
    "name": "Kashmir Paradise Portal",
    "slug": "kashmir-paradise-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kashmirportal",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.kashmir.paradiseportal",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Kashmir Portal uses the camera to let users add or update profile and listing photos.",
        "NSPhotoLibraryUsageDescription": "Kashmir Portal uses the photo library to let users choose images for listings and profiles.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kashmir.paradiseportal",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F2F4D7",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#0D3B2E",
          "defaultChannel": "portal-updates"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2F4D7",
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 190
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 190
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f2ed3e7-06df-446d-a885-dd528669b5f1"
      }
    }
  }
}
