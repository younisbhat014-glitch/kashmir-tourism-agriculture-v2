{
  "expo": {
    "name": "Kashmir Paradise Portal",
    "slug": "kashmir-paradise-portal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kashmirportal",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.kashmir.paradiseportal",
      "permissions": [
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F2F4D7",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2F4D7",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 190
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f2ed3e7-06df-446d-a885-dd528669b5f1"
      }
    }
  }
}
