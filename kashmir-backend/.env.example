MONGODB_URI=mongodb://localhost:27017/kashmir-portal
MONGODB_DB_NAME=kashmir-portal
MONGO_RETRY_MS=15000
JWT_SECRET=change-this-to-a-long-random-secret
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=https://frontend-one.up.railway.app,https://frontend-two.up.railway.app

# Confirmation email settings (Resend API is preferred on Railway)
RESEND_API_KEY=
RESEND_FROM=Kashmir Portal <onboarding@resend.dev>

# Optional SMTP fallback
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_REPLY_TO=info@kashmirportal.gov.in
MAIL_BRAND_NAME=Kashmir Tourism & Agriculture Portal
SUPPORT_EMAIL=info@kashmirportal.gov.in
SUPPORT_PHONE=+91-194-2452690
SUPPORT_ADDRESS=Tourist Reception Centre, Srinagar

# Optional AI chatbot settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CHATBOT_TIMEOUT_MS=18000

# Razorpay payment gateway (get keys from https://dashboard.razorpay.com -> Settings -> API Keys)
# Use Test Mode keys first (they start with rzp_test_). Switch to Live keys only after testing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
